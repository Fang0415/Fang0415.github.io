---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tag from '../components/Tag.astro';

const directions = ['RAG 系统', 'AI Agent', '后端设计', '开发工具链', 'VPS 网络'];
---

<BaseLayout title="关于" description="Fang0415 的个人技术档案。">
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 md:py-16 lg:px-8">
    <div class="border-y border-ink py-8">
      <p class="font-mono text-xs uppercase tracking-[0.16em] text-muted">关于作者</p>
      <h1 class="mt-5 max-w-4xl font-serif text-6xl font-bold leading-[0.95] md:text-8xl">Fang0415 的技术档案。</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">
        这里不是简历页。它更接近一份持续更新的技术档案：记录系统设计、工具链选择、失败案例和可复用的工程判断。
      </p>
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-[0.68fr_0.32fr]">
      <section>
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted">技术方向</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {directions.map((item) => <Tag label={item} />)}
        </div>
        <p class="mt-8 max-w-3xl text-base leading-8 text-muted">
          我关注实现细节真正重要的项目：数据流、可观测性、部署、失败模式和维护成本。这里记录的不只是最后跑起来的应用，也包括下次重写时仍然成立的工程判断。
        </p>
      </section>

      <aside class="h-fit border border-ink bg-soft p-6">
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted">联系</p>
        <dl class="mt-6 space-y-5 text-sm">
          <div>
            <dt class="font-mono text-xs uppercase tracking-[0.12em] text-muted">邮箱</dt>
            <dd class="mt-1">your-email@example.com</dd>
          </div>
          <div>
            <dt class="font-mono text-xs uppercase tracking-[0.12em] text-muted">GitHub</dt>
            <dd class="mt-1"><a href="https://github.com/Fang0415">github.com/Fang0415</a></dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>
</BaseLayout>
