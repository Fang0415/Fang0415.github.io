---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WritingList from '../../components/WritingList.astro';
import { toMeta, sortedPosts } from '../../lib/posts';

const posts = sortedPosts(await getCollection('blog', ({ data }) => !data.draft)).map(toMeta);
---

<BaseLayout title="全部文章" description="RAG、系统设计、AI 应用与工程实践文章归档，按发布时间倒序。">
  <section style="max-width: var(--max-content); margin: 0 auto; padding: 64px 24px 96px;">
    <span class="t-eyebrow" style="display: block; margin-bottom: 16px;">Writing</span>
    <h1 class="t-h1" style="font-size: clamp(36px, 6vw, 48px); margin-bottom: 16px;">全部文章</h1>
    <p class="t-body-lg" style="max-width: 62ch; color: var(--text-muted); margin-bottom: 48px;">
      按发布时间倒序。主题围绕 RAG 检索、系统设计、AI 应用与工程实践——记录踩过的坑和想明白的事。
    </p>
    <WritingList posts={posts} reveal={false} />
  </section>
</BaseLayout>
