---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WritingList from '../../components/WritingList.astro';
import { toMeta, sortedPosts } from '../../lib/posts';

const posts = sortedPosts(await getCollection('blog', ({ data }) => !data.draft)).map(toMeta);
---

<BaseLayout title="Writing" description="Notes on backend systems, RAG, and developer tooling.">
  <section class="page-head">
    <div class="kit-container">
      <h1 class="rise">Writing</h1>
      <p class="rise rise-2">
        Notes on backend systems, RAG, and developer tooling. I write to think things
        through and to keep what I learn reusable later.
      </p>
    </div>
  </section>

  <section class="kit-section" style="padding-top: 36px;">
    <div class="kit-container">
      <WritingList posts={posts} />
    </div>
  </section>
</BaseLayout>
