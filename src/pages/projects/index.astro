---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = [
  {
    name: '通用 RAG 系统',
    description: '围绕文档接入、切分策略、重排、提示词契约和评估链路整理的系统笔记。',
    stack: ['Python', 'RAG', 'Vector DB'],
    status: '持续记录',
  },
  {
    name: 'AI Agent 工作流',
    description: '记录 coding agent 的任务拆解、工具权限、审查循环和可复用交付习惯。',
    stack: ['Agents', 'Codex', 'Linear'],
    status: '写作中',
  },
  {
    name: '开发者博客',
    description: '基于 Astro 的中文技术博客，用于长文、项目记录和 GitHub Pages 发布。',
    stack: ['Astro', 'Tailwind', 'MDX'],
    status: '已上线',
  },
  {
    name: 'VPS 基础设施笔记',
    description: '记录服务器加固、反向代理、DNS、TLS、网络检查和故障复盘。',
    stack: ['Linux', 'Nginx', 'Network'],
    status: '资料归档',
  },
];

const archiveLanes = ['系统设计', '评估链路', '工具工作流', '部署运维'];
---

<BaseLayout title="项目" description="系统、Agent、工具链与基础设施项目记录。">
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 md:py-16 lg:px-8">
    <div class="border-y border-ink py-8">
      <p class="font-mono text-xs uppercase tracking-[0.16em] text-muted">项目记录</p>
      <h1 class="mt-5 max-w-4xl font-serif text-6xl font-bold leading-[0.95] md:text-8xl">文章背后的工程现场。</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-muted">
        项目页展示工程能力：问题定义、技术栈、状态、链接和后续复盘入口。它不是作品墙，而是可追溯的工程档案。
      </p>
    </div>

    <div class="mt-8 grid gap-px border border-hairline bg-hairline md:grid-cols-4">
      {archiveLanes.map((lane) => (
        <div class="bg-paper p-4">
          <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted">Archive lane</p>
          <p class="mt-2 text-lg font-semibold">{lane}</p>
        </div>
      ))}
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {projects.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>
</BaseLayout>
