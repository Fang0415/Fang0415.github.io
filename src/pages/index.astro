---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FeaturedShowcase from '../components/FeaturedShowcase.astro';
import PostCard from '../components/PostCard.astro';
import Card from '../components/Card.astro';
import Avatar from '../components/Avatar.astro';
import Button from '../components/Button.astro';
import SocialRow from '../components/SocialRow.astro';
import FolioIcon from '../components/FolioIcon.astro';
import { PROFILE } from '../lib/site';
import { toMeta, sortedPosts } from '../lib/posts';

const latest = sortedPosts(await getCollection('blog', ({ data }) => !data.draft))
  .slice(0, 3)
  .map(toMeta);
---

<BaseLayout>
  {/* Hero — image-led feature */}
  <section class="hero hero--feature">
    <div class="hero-banner rise">
      <img class="hero-banner-img" src="/assets/hero-sunflower.jpg"
        alt="A summer afternoon in a sunflower field" />
      <div class="kit-container hero-banner-inner">
        <p class="hero-eyebrow hero-eyebrow--on-image">
          <span class="hero-dot"></span>
          {PROFILE.role} <span class="loc">· {PROFILE.location}</span>
        </p>
        <h1>I build <em>{PROFILE.hero}</em>.</h1>
      </div>
    </div>
    <div class="kit-container hero-sub rise rise-2">
      <p class="hero-lead">{PROFILE.lead}</p>
      <div class="hero-actions">
        <Button variant="primary" href="/projects/">
          See what I've built
          <FolioIcon name="arrow-right" slot="icon-right" class="icon" />
        </Button>
        <Button variant="secondary" href="/blog/">Read the blog</Button>
      </div>
      <div class="hero-foot">
        <SocialRow />
        <p class="hero-now">
          <span class="hero-now-dot"></span>
          Now · building <strong>ragkit</strong> · writing up backend notes
        </p>
      </div>
    </div>
  </section>

  {/* Featured projects — pinned scroll showcase */}
  <FeaturedShowcase />

  {/* Latest writing */}
  <section class="kit-section kit-section--tight" style="background: var(--bg-soft);">
    <div class="kit-container">
      <div class="sec-head">
        <div>
          <p class="sec-eyebrow">Notes</p>
          <h2 class="sec-title">Writing</h2>
        </div>
        <a class="sec-link" href="/blog/">All posts <FolioIcon name="arrow-right" class="icon" /></a>
      </div>
      <div class="grid-3">
        {latest.map((post, i) => (
          <div class="cb-reveal" style={`--reveal-delay: ${i * 100}ms;`}>
            <PostCard
              layout="card"
              title={post.title}
              excerpt={post.excerpt}
              date={post.date}
              readingTime={post.readTime}
              category={post.category}
              href={post.href}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* About preview */}
  <section class="kit-section">
    <div class="kit-container">
      <Card padLg class="cb-reveal about-preview">
        <Avatar name={PROFILE.name} size="xl" />
        <div>
          <p class="sec-eyebrow" style="margin-bottom:8px;">About</p>
          <p style="font-size:var(--fs-h3); font-weight:600; line-height:1.5; margin:0; letter-spacing:-0.01em; max-width:32em;">
            I'm {PROFILE.name}, a backend engineer who likes small sharp tools and writing things down.
            Lately that means retrieval systems, evals, and the unglamorous plumbing that makes AI features reliable.
          </p>
        </div>
        <Button variant="ghost" href="/about/">
          More
          <FolioIcon name="arrow-right" slot="icon-right" class="icon" />
        </Button>
      </Card>
    </div>
  </section>
</BaseLayout>
