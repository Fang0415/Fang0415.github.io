---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Tag from '../components/Tag.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const focus = ['RAG 系统与评估', 'AI Agent 工作流', '后端工程实践', 'VPS 与网络配置'];
const stack = ['Java', 'Python', 'Astro', 'FastAPI', 'PostgreSQL', 'Docker', 'GitHub', 'Linear', 'Codex'];
const garden = [
  {
    label: 'Essays',
    title: '长文',
    description: '系统性整理一个工程问题，保留背景、权衡、实现和复盘。',
  },
  {
    label: 'Notes',
    title: '短笔记',
    description: '记录调试过程、工具用法、配置片段和临时观察。',
  },
  {
    label: 'Garden',
    title: '知识花园',
    description: '沉淀长期主题：RAG、Agent、后端、DevTools、网络基础设施。',
  },
  {
    label: 'Patterns',
    title: '工程模式',
    description: '抽取可复用的架构决策、工作流和问题排查框架。',
  },
];
const projects = [
  {
    name: '通用 RAG 系统笔记',
    description: '记录文档切分、召回、重排、提示词契约与答案评估的实践过程。',
    stack: ['RAG', 'Python', 'Eval'],
    status: '持续记录',
  },
  {
    name: 'AI Agent 工作流',
    description: '整理 coding agent 的任务拆解、工具边界、审查循环和交付清单。',
    stack: ['Agents', 'Codex', 'Linear'],
    status: '写作中',
  },
];
---

<BaseLayout title="Fang 的技术博客" description="记录 RAG、AI Agent、后端工程、开发工具链与网络基础设施的中文技术博客。">
  <section class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 md:grid-cols-[1fr_380px] md:py-16 lg:px-8">
    <div>
      <p class="border-y border-ink py-3 font-mono text-xs uppercase tracking-[0.16em] text-muted">
        Fang0415 / 技术博客 / 长期笔记
      </p>
      <h1 class="mt-8 max-w-5xl font-serif text-6xl font-bold leading-[0.95] md:text-8xl">
        RAG、Agent、后端和工具链的长期技术档案。
      </h1>
      <p class="mt-7 max-w-2xl text-lg leading-8 text-muted">
        我把学习、开发、部署和踩坑过程整理成中文文章。这里同时是个人技术杂志、工程项目档案和数字花园入口：文章优先，作者在场，项目作为上下文。
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/blog/" class="border border-ink bg-ink px-5 py-3 text-sm font-bold text-white no-underline hover:bg-white hover:text-ink">阅读文章</a>
        <a href="/about/" class="border border-ink px-5 py-3 text-sm font-bold no-underline hover:bg-soft hover:text-ink">了解作者</a>
      </div>
    </div>
    <aside class="border border-ink bg-soft p-5">
      <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted">作者档案</p>
      <h2 class="mt-4 font-serif text-4xl font-bold leading-none">Fang0415</h2>
      <p class="mt-4 text-sm leading-6 text-muted">
        关注 AI 应用工程、后端系统、开发工具链和基础设施配置。写作目标是把一次性的工程经验沉淀成下次能复用的判断。
      </p>
      <p class="mt-8 font-mono text-xs uppercase tracking-[0.12em] text-muted">最近关注</p>
      <ul class="mt-6 space-y-4">
        {focus.map((item) => (
          <li class="border-t border-hairline pt-4 text-lg font-semibold leading-tight">{item}</li>
        ))}
      </ul>
    </aside>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <SectionHeading eyebrow="研究地图" title="从文章进入长期知识库。" description="参考数字花园的信息组织方式：不是所有内容都必须成为完整长文，短笔记、模式和阅读记录也应该有位置。" />
    <div class="mt-8 grid gap-px border border-ink bg-ink md:grid-cols-4">
      {garden.map((item) => (
        <article class="bg-paper p-5 transition duration-150 hover:bg-soft">
          <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted">{item.label}</p>
          <h3 class="mt-5 font-serif text-3xl font-bold leading-none">{item.title}</h3>
          <p class="mt-4 text-sm leading-6 text-muted">{item.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <SectionHeading eyebrow="精选文章" title="先看最近写了什么。" description="文章列表遵循极简技术索引：日期、标题、摘要和标签直接构成内容判断，不做普通卡片墙。" />
    <div class="mt-8">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          href={`/blog/${post.slug}/`}
        />
      ))}
    </div>
    <a href="/blog/" class="mt-6 inline-flex border border-ink px-4 py-2 text-sm font-bold no-underline hover:bg-ink hover:text-white">查看全部文章</a>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <SectionHeading eyebrow="项目笔记" title="文章背后的工程上下文。" description="项目区保留工程感，但不抢文章的位置。它用于说明长期关注的问题域。" />
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      {projects.map((project) => <ProjectCard {...project} />)}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <SectionHeading eyebrow="技术标签" title="这个博客常出现的工具和主题。" />
    <div class="mt-8 flex flex-wrap gap-2">
      {stack.map((item) => <Tag label={item} />)}
    </div>
  </section>
</BaseLayout>
