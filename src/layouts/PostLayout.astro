---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const date = post.data.pubDate.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <a href="/blog/" class="font-mono text-xs uppercase tracking-[0.12em] text-muted no-underline hover:text-ink">
      返回文章列表
    </a>

    <header class="mt-8 border-y border-ink py-8 md:py-12">
      <div class="max-w-4xl">
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted">
          Fang0415 / 
          <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        </p>
        <h1 class="mt-5 font-serif text-5xl font-bold leading-[0.92] md:text-7xl">{post.data.title}</h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-muted">{post.data.description}</p>
        <div class="mt-6 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => <Tag label={tag} />)}
        </div>
      </div>
    </header>

    <div class="mx-auto mt-12 max-w-[780px]">
      <aside class="mb-10 border-y border-hairline py-4 text-sm leading-6 text-muted">
        <div class="grid gap-3 sm:grid-cols-3">
          <p><span class="font-mono text-xs uppercase tracking-[0.12em]">作者</span><br />Fang0415</p>
          <p><span class="font-mono text-xs uppercase tracking-[0.12em]">栏目</span><br />技术文章</p>
          <p><span class="font-mono text-xs uppercase tracking-[0.12em]">主题</span><br />{post.data.tags.join(' / ')}</p>
        </div>
      </aside>
      <div class="article-content">
        <slot />
      </div>
      <div class="mt-12 border-t border-hairline pt-6">
        <a href="/blog/" class="font-mono text-xs uppercase tracking-[0.12em] text-muted no-underline hover:text-ink">
          回到文章归档
        </a>
      </div>
    </div>
  </article>
</BaseLayout>
