---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';
import Button from '../components/Button.astro';
import { toMeta } from '../lib/posts';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const meta = toMeta(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article style="max-width: 720px; margin: 0 auto; padding: 64px 24px 96px;">
    <a
      href="/blog/"
      style="font-family: var(--font-mono); font-size: 13px; color: var(--text-muted); text-decoration: none; display: inline-block; margin-bottom: 32px;"
    >
      ← 返回文章列表
    </a>

    <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
      <Tag color={meta.categoryColor}>{meta.category}</Tag>
      <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);">{meta.date}</span>
      <span style="width: 3px; height: 3px; border-radius: 50%; background: var(--charcoal-40);"></span>
      <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);">{meta.readTime}</span>
    </div>

    <h1 class="t-h1" style="font-size: clamp(32px, 5vw, 44px); line-height: 1.1; margin-bottom: 24px;">
      {post.data.title}
    </h1>

    <p
      class="t-body-lg"
      style="color: var(--text-muted); margin-bottom: 40px; padding-bottom: 32px; border-bottom: 1px solid var(--border-subtle);"
    >
      {post.data.description}
    </p>

    <div class="article-body">
      <slot />
    </div>

    <div style="margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--border-subtle); display: flex; gap: 12px; flex-wrap: wrap;">
      <Button variant="ghost" href="/blog/">← 回到文章列表</Button>
      <Button variant="cream" href="/rss.xml">订阅后续更新</Button>
    </div>
  </article>
</BaseLayout>
