---
// Tag — Folio mono label for tech stacks, categories, statuses.
// Variants tint with the brand ramp. Ported from Folio core/Tag.jsx.
interface Props {
  variant?: 'default' | 'solid' | 'teal' | 'amber' | 'sky';
  mono?: boolean;
  dot?: boolean;
  href?: string;
  class?: string;
  style?: string;
}

const {
  variant = 'default',
  mono = true,
  dot = false,
  href,
  class: className = '',
  style = '',
} = Astro.props;

const cls = `folio-tag folio-tag--${variant} ${mono ? '' : 'folio-tag--sans'} ${className}`.trim();
const Tag = href ? 'a' : 'span';
---

<Tag class={cls} href={href} style={style}>
  {dot && <span class="folio-tag__dot" aria-hidden="true" />}
  <slot />
</Tag>
