---
// ProjectCard — name, description, tech tags, status, entry link.
// Bordered cream card, border darkens on hover. Ported from blog/ProjectCard.jsx.
import Card from './Card.astro';
import Tag from './Tag.astro';
import StatusBadge from './StatusBadge.astro';

interface Props {
  name: string;
  description: string;
  tags?: string[];
  status?: 'active' | 'wip' | 'paused' | 'archived';
  statusLabel?: string;
  href?: string;
  class?: string;
}

const {
  name,
  description,
  tags = [],
  status = 'active',
  statusLabel = '运行中',
  href = '#',
  class: className = '',
} = Astro.props;
---

<Card interactive pad="none" class={className} style="display: flex; flex-direction: column;">
  <div style="padding: 24px 24px 20px;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 10px;">
      <h3
        style="font-size: var(--card-title-size); line-height: var(--card-title-line); letter-spacing: var(--card-title-track); font-weight: var(--weight-semibold); color: var(--text-strong); margin: 0;"
      >
        {name}
      </h3>
      <StatusBadge status={status} style="flex: none;">{statusLabel}</StatusBadge>
    </div>
    <p style="font-size: var(--body-size); line-height: 1.55; color: var(--text-muted); margin: 0 0 18px;">
      {description}
    </p>
    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
      {tags.map((t) => <Tag>{t}</Tag>)}
    </div>
  </div>
  <a
    href={href}
    style="margin-top: auto; padding: 14px 24px; border-top: 1px solid var(--border-subtle); font-family: var(--font-mono); font-size: 13px; color: var(--text-strong); text-decoration: none; display: flex; align-items: center; gap: 6px;"
  >
    查看项目 <span class="cb-arrow" aria-hidden="true">→</span>
  </a>
</Card>
