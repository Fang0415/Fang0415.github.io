---
// ProjectCard — Folio project tile. Title (whole-card click target via a
// ::after overlay), status badge, description, stack tags, repo/demo links.
// The Card stays a <div> so the repo/demo links can nest legally.
// Ported from Folio cards/ProjectCard.jsx.
import Card from './Card.astro';
import Tag from './Tag.astro';
import Badge from './Badge.astro';

interface Props {
  title: string;
  description?: string;
  stack?: string[];
  status?: 'active' | 'building' | 'shipped' | 'archived';
  href?: string;
  repo?: string;
  demo?: string;
  class?: string;
  style?: string;
}

const {
  title,
  description,
  stack = [],
  status,
  href,
  repo,
  demo,
  class: className = '',
  style = '',
} = Astro.props;

const STATUS_VARIANT: Record<string, 'success' | 'warning' | 'brand' | 'neutral'> = {
  active: 'success',
  building: 'warning',
  shipped: 'brand',
  archived: 'neutral',
};
const statusLabel = status ? status.charAt(0).toUpperCase() + status.slice(1) : '';
---

<Card interactive={!!href} class={className} style={style}>
  <div class="folio-project">
    <div class="folio-project__head">
      <h3 class="folio-project__title">
        {href ? <a class="folio-project__titlelink" href={href}>{title}</a> : title}
      </h3>
      {status && (
        <Badge variant={STATUS_VARIANT[status] || 'neutral'} dot>{statusLabel}</Badge>
      )}
    </div>
    {description && <p class="folio-project__desc">{description}</p>}
    {stack.length > 0 && (
      <div class="folio-project__tags">
        {stack.map((s) => <Tag>{s}</Tag>)}
      </div>
    )}
    {(repo || demo) && (
      <div class="folio-project__foot">
        {repo && <a href={repo}>⌥ Code</a>}
        {demo && <a href={demo}>↗ Demo</a>}
      </div>
    )}
  </div>
</Card>
