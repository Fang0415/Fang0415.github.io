---
// Navbar — Folio floating nav. Transparent and unified with the hero on
// the home page; collapses into a glass capsule on scroll (and stays a
// capsule on the inner pages, which have no hero image).
// Ported from Folio Chrome.jsx FolioNav + kit.css nav rules.
import Button from './Button.astro';
import FolioIcon from './FolioIcon.astro';
import { PROFILE, NAV_LINKS } from '../lib/site';

const path = Astro.url.pathname;
const isHome = path === '/' || path === '';
// Active link by path prefix (home matches only '/').
const isActive = (href: string) =>
  href === '/' ? isHome : path.startsWith(href);
---

<nav class="folio-nav" data-home={isHome ? 'true' : 'false'}>
  <div class="folio-nav__inner">
    <a class="folio-nav__brand" href="/">
      <span class="folio-nav__mark">{PROFILE.mark}</span>{PROFILE.wordmark}
    </a>
    <div class="folio-nav__links">
      {NAV_LINKS.map((l) => (
        <a
          href={l.href}
          class={`folio-nav__link ${isActive(l.href) ? 'folio-nav__link--active' : ''}`.trim()}
        >
          {l.label}
        </a>
      ))}
    </div>
    <div class="folio-nav__right">
      <Button size="sm" variant="primary" href="/rss.xml">
        <FolioIcon name="rss" slot="icon-left" class="icon" />
        Subscribe
      </Button>
      <button class="folio-nav__menu" id="cb-menu-open" aria-label="Menu">
        <FolioIcon name="menu" class="icon" />
      </button>
    </div>
  </div>
</nav>

<script>
  // Home: transparent at the very top, glass capsule once scrolled.
  // Inner pages (no hero image): always a glass capsule.
  const nav = document.querySelector<HTMLElement>('nav.folio-nav');
  const isHome = nav?.dataset.home === 'true';
  const onScroll = () => {
    const collapsed = !isHome || window.scrollY > 16;
    document.body.classList.toggle('nav-scrolled', collapsed);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
