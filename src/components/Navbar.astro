---
// Navbar — sticky cream navigation. Wordmark left, links center, social
// icons + mobile menu button right. Hairline bottom border on scroll.
// Ported from cream-blog-design-system navigation/Navbar.jsx.
interface Props {
  brand?: string;
}

const {
  brand = '/dev/null',
} = Astro.props;

const links = [
  { label: '关于我', href: '/#about' },
  { label: '项目', href: '/#projects' },
  { label: '文章', href: '/blog/' },
  { label: '联系我', href: '/#contact' },
];

const linkStyle =
  'font-size: 15px; color: var(--text-secondary); text-decoration: none;';
const iconLink =
  'display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: var(--radius-pill); color: var(--text-strong); opacity: 0.55; text-decoration: none;';
---

<header
  id="cb-navbar"
  style="position: sticky; top: 0; z-index: 50; background: var(--surface-page); border-bottom: 1px solid transparent; transition: background 0.2s ease, border-color 0.2s ease, backdrop-filter 0.2s ease;"
>
  <nav style="max-width: var(--max-content); margin: 0 auto; padding: 16px 24px; display: flex; align-items: center; gap: 24px;">
    <a
      href="/"
      style="font-family: var(--font-mono); font-size: 15px; font-weight: 500; color: var(--text-strong); text-decoration: none; letter-spacing: -0.01em;"
    >
      {brand}
    </a>
    <div class="cb-nav-links" style="display: flex; gap: 26px; margin-left: 16px;">
      {links.map((l) => (
        <a class="cb-navlink" href={l.href} style={linkStyle}>{l.label}</a>
      ))}
    </div>
    <div style="margin-left: auto; display: flex; align-items: center; gap: 4px;">
      <a class="cb-nav-icons cb-iconlink" href="https://github.com" aria-label="GitHub" style={iconLink}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 .5 5 .5 5 .5c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 7.5c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      </a>
      <a class="cb-nav-icons cb-iconlink" href="mailto:hi@example.com" aria-label="Email" style={iconLink}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
      <a class="cb-nav-icons cb-iconlink" href="/rss.xml" aria-label="RSS" style={`${iconLink} margin-right: 8px;`}>
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      </a>
      <button
        class="cb-nav-menu"
        id="cb-menu-open"
        aria-label="菜单"
        style="display: none; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: var(--radius-sm); background: transparent; border: 1px solid var(--border-interactive); color: var(--text-strong); cursor: pointer;"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
      </button>
    </div>
  </nav>
</header>

<script>
  // Hairline border + translucent blur once the page is scrolled.
  const nav = document.getElementById('cb-navbar');
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 8) {
        nav.style.background = 'rgba(247,244,237,0.86)';
        nav.style.backdropFilter = 'saturate(1.2) blur(8px)';
        nav.style.borderBottomColor = 'var(--border-subtle)';
      } else {
        nav.style.background = 'var(--surface-page)';
        nav.style.backdropFilter = 'none';
        nav.style.borderBottomColor = 'transparent';
      }
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>
