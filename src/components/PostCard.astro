---
import Tag from './Tag.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  href: string;
  readingTime?: string;
}

const { title, description, pubDate, tags, href, readingTime } = Astro.props;
const date = pubDate.toLocaleDateString('en', {
  year: 'numeric',
  month: 'short',
  day: '2-digit',
});
---

<article class="group border-t border-hairline py-7 first:border-ink">
  <a href={href} class="grid gap-4 no-underline md:grid-cols-[160px_1fr]">
    <div class="font-mono text-xs uppercase tracking-[0.08em] text-muted">
      <time datetime={pubDate.toISOString()}>{date}</time>
      {readingTime && <p class="mt-2">{readingTime}</p>}
    </div>
    <div>
      <h2 class="font-serif text-3xl font-bold leading-[1.02] group-hover:text-linear md:text-4xl">{title}</h2>
      <p class="mt-3 max-w-3xl text-base leading-7 text-muted">{description}</p>
      <div class="mt-4 flex flex-wrap gap-2">
        {tags.map((tag) => <Tag label={tag} />)}
      </div>
    </div>
  </a>
</article>
