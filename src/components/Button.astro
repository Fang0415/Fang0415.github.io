---
// Button — primary action element. Three variants: primary (dark, inset
// shadow), ghost (outline), cream (flat surface). Renders <a> if href set.
// Ported from cream-blog-design-system core/Button.jsx.
interface Props {
  variant?: 'primary' | 'ghost' | 'cream';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: className = '' } = Astro.props;

const base =
  'display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-family: var(--font-sans); font-weight: var(--weight-regular); line-height: 1.5; border-radius: var(--radius-sm); cursor: pointer; text-decoration: none; white-space: nowrap; border: 1px solid transparent; box-sizing: border-box;';

const sizes: Record<string, string> = {
  sm: 'padding: 6px 12px; font-size: var(--caption-size);',
  md: 'padding: 9px 16px; font-size: var(--body-size);',
  lg: 'padding: 12px 22px; font-size: var(--body-lg-size);',
};

const variants: Record<string, string> = {
  primary:
    'background: var(--btn-primary-bg); color: var(--btn-primary-fg); box-shadow: var(--shadow-inset);',
  ghost:
    'background: transparent; color: var(--btn-ghost-fg); border: 1px solid var(--btn-ghost-border);',
  cream: 'background: var(--surface-card); color: var(--text-strong);',
};

const style = `${base}${sizes[size]}${variants[variant]}`;
const Tag = href ? 'a' : 'button';
---

<Tag class:list={['cb-btn', className]} href={href} style={style}>
  <slot />
</Tag>
