---
// Button — Folio CTA. Variants: primary (gold), secondary (outline),
// ghost, text. Pill geometry. Renders <a> when href is set.
// Ported from Folio core/Button.jsx.
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'text';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  style?: string;
}

const { variant = 'primary', size = 'md', href, class: className = '', style = '' } = Astro.props;
const cls = `folio-btn folio-btn--${variant} folio-btn--${size} ${className}`.trim();
const Tag = href ? 'a' : 'button';
const hasLeft = Astro.slots.has('icon-left');
const hasRight = Astro.slots.has('icon-right');
---

<Tag class={cls} href={href} style={style}>
  {hasLeft && <span class="folio-btn__icon" aria-hidden="true"><slot name="icon-left" /></span>}
  <span><slot /></span>
  {hasRight && <span class="folio-btn__icon" aria-hidden="true"><slot name="icon-right" /></span>}
</Tag>
