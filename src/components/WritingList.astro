---
// WritingList — Folio post list (row layout) with a category filter bar and
// optional search pill. Used on the homepage and the /blog archive.
import PostCard from './PostCard.astro';
import FolioIcon from './FolioIcon.astro';
import { CATEGORY_ORDER, type PostMeta } from '../lib/posts';

interface Props {
  posts: PostMeta[];
  search?: boolean;
}

const { posts, search = true } = Astro.props;

// Only show category chips that actually have posts.
const present = CATEGORY_ORDER.filter((c) => posts.some((p) => p.category === c));
const categories = ['All', ...present];
---

<div data-writing-list>
  <div class="filter-bar">
    {categories.map((c) => (
      <button class={`filter-chip ${c === 'All' ? 'filter-chip--active' : ''}`} data-filter={c}>{c}</button>
    ))}
    {search && (
      <>
        <span class="filter-spacer"></span>
        <div class="wl-search">
          <FolioIcon name="search" class="icon" />
          <input type="search" placeholder="Search posts…" data-writing-search aria-label="Search posts" />
        </div>
      </>
    )}
  </div>

  <div class="post-list" data-writing-items>
    {posts.map((p) => (
      <div data-category={p.category} data-haystack={`${p.title} ${p.excerpt}`.toLowerCase()}>
        <PostCard
          layout="row"
          title={p.title}
          excerpt={p.excerpt}
          date={p.date}
          href={p.href}
          tags={[p.category]}
        />
      </div>
    ))}
  </div>
  <div class="wl-empty" data-writing-empty hidden>No posts match your search.</div>
</div>

<style>
  .wl-search {
    display: flex; align-items: center; gap: 8px; width: 240px;
    padding: 7px 14px; border-radius: var(--radius-full);
    background: var(--bg-soft); border: 1px solid var(--border-default);
    color: var(--text-muted); transition: border-color .15s ease, background .15s ease;
  }
  .wl-search:focus-within { border-color: var(--border-strong); background: var(--surface-card); }
  .wl-search .icon { width: 16px; height: 16px; flex: none; }
  .wl-search input {
    border: none; outline: none; background: none; width: 100%;
    font-family: var(--font-sans); font-size: var(--fs-body-sm); color: var(--text-primary);
  }
  .wl-empty {
    padding: 48px 0; text-align: center; color: var(--text-muted);
    font-family: var(--font-mono); font-size: 13px;
  }
</style>

<script>
  document.querySelectorAll('[data-writing-list]').forEach((root) => {
    const buttons = root.querySelectorAll<HTMLButtonElement>('.filter-chip');
    const items = root.querySelectorAll<HTMLElement>('[data-writing-items] > [data-category]');
    const searchEl = root.querySelector<HTMLInputElement>('[data-writing-search]');
    const empty = root.querySelector<HTMLElement>('[data-writing-empty]');
    let cat = 'All';
    let q = '';

    const apply = () => {
      let shown = 0;
      items.forEach((it) => {
        const inCat = cat === 'All' || it.dataset.category === cat;
        const inQ = !q || (it.dataset.haystack || '').includes(q);
        const show = inCat && inQ;
        it.style.display = show ? '' : 'none';
        if (show) shown++;
      });
      if (empty) empty.hidden = shown !== 0;
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        cat = btn.dataset.filter || 'All';
        buttons.forEach((b) => b.classList.toggle('filter-chip--active', b === btn));
        apply();
      });
    });
    searchEl?.addEventListener('input', () => { q = searchEl.value.trim().toLowerCase(); apply(); });
  });
</script>
