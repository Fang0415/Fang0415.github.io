---
// ArticleCard — editorial article row. Mono meta line (category · date ·
// read time), title, lead. Reads generously. Ported from blog/ArticleCard.jsx.
import Tag from './Tag.astro';

interface Props {
  title: string;
  excerpt: string;
  date: string;
  category: string;
  categoryColor?: 'clay' | 'ochre' | 'sage' | 'slate';
  readTime: string;
  href?: string;
  class?: string;
}

const {
  title,
  excerpt,
  date,
  category,
  categoryColor = 'clay',
  readTime,
  href = '#',
  class: className = '',
} = Astro.props;
---

<a
  href={href}
  class:list={['cb-article-card', className]}
  style="display: block; text-decoration: none; padding: 26px 0; border-bottom: 1px solid var(--border-subtle);"
>
  <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; row-gap: 6px;">
    <Tag color={categoryColor}>{category}</Tag>
    <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); white-space: nowrap;">
      {date}
    </span>
    <span style="width: 3px; height: 3px; border-radius: 50%; background: var(--charcoal-40);"></span>
    <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); white-space: nowrap;">
      {readTime}
    </span>
  </div>
  <h3
    style="font-size: var(--h3-size); line-height: 1.25; letter-spacing: var(--h3-track); font-weight: var(--weight-semibold); color: var(--text-strong); margin: 0 0 10px;"
  >
    {title}
  </h3>
  <p style="font-size: var(--body-lg-size); line-height: 1.5; color: var(--text-muted); margin: 0; max-width: 60ch;">
    {excerpt}
  </p>
</a>
