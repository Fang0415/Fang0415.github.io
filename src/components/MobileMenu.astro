---
// MobileMenu — full-screen cream overlay for the collapsed nav. Hidden by
// default; toggled by the Navbar hamburger (see script below).
// Ported from cream-blog-design-system navigation/MobileMenu.jsx.
const links = [
  { label: '关于我', href: '/#about' },
  { label: '项目', href: '/#projects' },
  { label: '文章', href: '/blog/' },
  { label: '联系我', href: '/#contact' },
];
---

<div
  id="cb-mobile-menu"
  hidden
  style="position: fixed; inset: 0; z-index: 100; background: var(--surface-page); flex-direction: column; padding: 20px 24px 40px;"
>
  <div style="display: flex; justify-content: space-between; align-items: center;">
    <span style="font-family: var(--font-mono); font-size: 15px; font-weight: 500; color: var(--text-strong);">
      /dev/null
    </span>
    <button
      id="cb-menu-close"
      aria-label="关闭"
      style="width: 38px; height: 38px; border-radius: var(--radius-sm); background: transparent; border: 1px solid var(--border-interactive); color: var(--text-strong); cursor: pointer; display: inline-flex; align-items: center; justify-content: center;"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
    </button>
  </div>
  <div style="display: flex; flex-direction: column; gap: 4px; margin-top: 48px;">
    {links.map((l) => (
      <a
        class="cb-menu-link"
        href={l.href}
        style="font-size: 32px; letter-spacing: -0.02em; font-weight: var(--weight-semibold); color: var(--text-strong); text-decoration: none; padding: 10px 0; border-bottom: 1px solid var(--border-subtle);"
      >
        {l.label}
      </a>
    ))}
  </div>
  <div style="margin-top: auto; display: flex; gap: 20px; font-family: var(--font-mono); font-size: 14px;">
    <a href="https://github.com" style="color: var(--text-secondary); text-decoration: none;">GitHub</a>
    <a href="mailto:hi@example.com" style="color: var(--text-secondary); text-decoration: none;">Email</a>
    <a href="/rss.xml" style="color: var(--text-secondary); text-decoration: none;">RSS</a>
  </div>
</div>

<script>
  const menu = document.getElementById('cb-mobile-menu');
  const openBtn = document.getElementById('cb-menu-open');
  const closeBtn = document.getElementById('cb-menu-close');
  const open = () => {
    if (!menu) return;
    menu.hidden = false;
    menu.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  };
  const close = () => {
    if (!menu) return;
    menu.hidden = true;
    menu.style.display = 'none';
    document.body.style.overflow = '';
  };
  openBtn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  menu?.querySelectorAll('.cb-menu-link').forEach((a) => a.addEventListener('click', close));
</script>
