---
// SocialRow — the icon cluster used in the hero, footer, and about page.
// Ported from Folio Chrome.jsx SocialRow.
import IconButton from './IconButton.astro';
import FolioIcon from './FolioIcon.astro';
import { PROFILE } from '../lib/site';

interface Props {
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}
const { size = 'md', class: className = '' } = Astro.props;
---

<div class={`social-row ${className}`.trim()}>
  <IconButton label="GitHub" href={PROFILE.github} size={size}><FolioIcon name="github" /></IconButton>
  <IconButton label="X" href={PROFILE.x} size={size}><FolioIcon name="x" /></IconButton>
  <IconButton label="RSS" href="/rss.xml" size={size}><FolioIcon name="rss" /></IconButton>
  <IconButton label="Email" href={`mailto:${PROFILE.email}`} size={size}><FolioIcon name="mail" /></IconButton>
</div>
