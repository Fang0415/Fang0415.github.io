---
interface Props {
  eyebrow: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="border-t border-ink pt-4">
  <p class="font-mono text-xs uppercase tracking-[0.12em] text-muted">{eyebrow}</p>
  <div class="mt-3 grid gap-4 md:grid-cols-[minmax(0,0.72fr)_minmax(280px,0.28fr)] md:items-end">
    <h2 class="font-serif text-4xl font-bold leading-[0.95] md:text-5xl">{title}</h2>
    {description && <p class="text-sm leading-6 text-muted md:text-base">{description}</p>}
  </div>
</div>
