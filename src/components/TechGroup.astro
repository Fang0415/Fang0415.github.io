---
// TechGroup — grouped tech-stack card: a mono group label and a wrapped
// list of restrained text items. Ported from blog/TechGroup.jsx.
import Card from './Card.astro';

type Item = string | { name: string; note?: string };

interface Props {
  label: string;
  items?: Item[];
  color?: 'clay' | 'ochre' | 'sage' | 'slate';
  class?: string;
}

const { label, items = [], color, class: className = '' } = Astro.props;

const dotMap = {
  clay: 'var(--clay)',
  ochre: 'var(--ochre)',
  sage: 'var(--sage)',
  slate: 'var(--slate)',
} as const;
const dot = color ? dotMap[color] : null;
---

<Card pad="md" radius="card" class={className}>
  <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 14px;">
    {dot && (
      <span style={`width: 7px; height: 7px; border-radius: var(--radius-pill); background: ${dot}; flex: none;`}></span>
    )}
    <span style="font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted);">
      {label}
    </span>
  </div>
  <div style="display: flex; flex-direction: column; gap: 9px;">
    {items.map((it) => (
      <div style="display: flex; align-items: baseline; justify-content: space-between; gap: 12px;">
        <span style="font-size: 15px; color: var(--text-strong);">
          {typeof it === 'string' ? it : it.name}
        </span>
        {typeof it !== 'string' && it.note ? (
          <span style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);">
            {it.note}
          </span>
        ) : null}
      </div>
    ))}
  </div>
</Card>
