---
// Card — Folio base container. White (or soft cream) surface, hairline
// border, 12px radius, no shadow at rest. Interactive cards lift on hover.
// Ported from Folio cards/Card.jsx.
interface Props {
  interactive?: boolean;
  soft?: boolean;
  padLg?: boolean;
  dark?: boolean;
  href?: string;
  class?: string;
  style?: string;
}

const {
  interactive = false,
  soft = false,
  padLg = false,
  dark = false,
  href,
  class: className = '',
  style = '',
} = Astro.props;

const cls = [
  'folio-card',
  interactive ? 'folio-card--interactive' : '',
  soft ? 'folio-card--soft' : '',
  padLg ? 'folio-card--pad-lg' : '',
  dark ? 'folio-card--dark' : '',
  className,
].filter(Boolean).join(' ');

const Tag = href ? 'a' : 'div';
---

<Tag class={cls} href={href} style={style}>
  <slot />
</Tag>
