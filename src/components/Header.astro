---
const links = [
  { href: '/', label: '首页' },
  { href: '/blog/', label: '文章' },
  { href: '/projects/', label: '项目' },
  { href: '/about/', label: '关于' },
];
---

<header class="border-b border-ink bg-paper">
  <nav class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
    <a href="/" class="font-mono text-sm font-bold uppercase tracking-[0.16em] no-underline">
      Fang 的技术博客
    </a>
    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm font-semibold text-muted">
      {links.map((link) => (
        <a class="no-underline hover:text-ink" href={link.href}>{link.label}</a>
      ))}
    </div>
  </nav>
</header>
