---
// StatusBadge — small status indicator with a desaturated colored dot.
// Ported from cream-blog-design-system core/StatusBadge.jsx.
interface Props {
  status?: 'active' | 'wip' | 'paused' | 'archived';
  class?: string;
  style?: string;
}

const { status = 'active', class: className = '', style = '' } = Astro.props;

const dots: Record<string, string> = {
  active: '#5b8c6e',
  wip: '#b08948',
  paused: 'var(--charcoal-40)',
  archived: 'var(--charcoal-40)',
};

const base =
  'display: inline-flex; align-items: center; gap: 7px; font-family: var(--font-mono); font-size: 12px; color: var(--text-muted);';
---

<span class={className} style={`${base}${style}`}>
  <span
    style={`width: 7px; height: 7px; border-radius: var(--radius-pill); background: ${dots[status]}; flex: none;`}
  ></span>
  <slot />
</span>
